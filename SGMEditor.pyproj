<?xml version="1.0" encoding="utf-8"?>
<Project DefaultTargets="Build" ToolsVersion="4.0" xmlns="http://schemas.microsoft.com/developer/msbuild/2003">
  <PropertyGroup>
    <Configuration Condition=" '$(Configuration)' == '' ">Debug</Configuration>
    <SchemaVersion>2.0</SchemaVersion>
    <ProjectGuid>{D95A7F89-AB8E-4F6A-B29D-4D4E8C1B3A9F}</ProjectGuid>
    <ProjectHome>.</ProjectHome>
    <StartupFile>sg-editor.py</StartupFile>
    <SearchPath />
    <WorkingDirectory>.</WorkingDirectory>
    <OutputPath>.</OutputPath>
    <Name>SGMEditor</Name>
    <RootNamespace>SGMEditor</RootNamespace>
    <LaunchProvider>Standard Python launcher</LaunchProvider>
    <InterpreterId>Global|PythonCore|3.11</InterpreterId>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Debug' ">
    <DebugSymbols>true</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <PropertyGroup Condition=" '$(Configuration)' == 'Release' ">
    <DebugSymbols>false</DebugSymbols>
    <EnableUnmanagedDebugging>false</EnableUnmanagedDebugging>
  </PropertyGroup>
  <ItemGroup>
    <Compile Include="sg-editor.py" />
  </ItemGroup>
  <ItemGroup>
    <Content Include="editor_layout.json" />
    <Content Include="app_settings.json" />
    <Content Include="build-exe.bat" />
    <Content Include="requirements-build.txt" />
    <Content Include="run-editor.bat" />
    <Content Include="run-editor-rpc.bat" />
    <Content Include="run-checks.bat" />
    <Content Include="sg-editor.spec" />
    <Content Include="README.md" />
  </ItemGroup>
  <ItemGroup>
    <Folder Include="assets\" />
    <Folder Include="discordrpc\" />
  </ItemGroup>
  <Import Project="$(MSBuildExtensionsPath32)\Microsoft\VisualStudio\v$(VisualStudioVersion)\Python Tools\Microsoft.PythonTools.targets" />
</Project>
